{
  "name": "kinetik",
  "version": "0.1.0",
  "description": "Drag-and-drop that feels native. Velocity prediction, inertial throw, View Transitions API, keyboard sensor — ~12KB gzipped.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./modifiers": {
      "types": "./dist/modifiers/index.d.ts",
      "import": "./dist/modifiers/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "deps:check": "npx npm-check-updates",
    "deps:update": "npx npm-check-updates -u && npm install --package-lock-only && npm install",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "vitest run && playwright test --project=chromium --grep-invert=\"Stress test|frame time|no forced layout|rapid pointerdown\" --reporter=line --workers=1",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --project=chromium --reporter=line --workers=1",
    "test:e2e:install": "playwright install chromium",
    "demo": "cd demo && npm install && npm run dev",
    "demo:build": "cd demo && npm run build",
    "bench": "tsx bench/bench.ts",
    "bench:frame": "tsx bench/micro-frame.bench.ts",
    "bench:alloc": "tsx bench/allocation.bench.ts",
    "prepublishOnly": "npm run build && npm run test:unit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "happy-dom": "^20.11.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "drag-and-drop",
    "dnd",
    "sortable",
    "kanban",
    "react",
    "react-hooks",
    "native",
    "smooth",
    "accessible",
    "a11y",
    "keyboard",
    "view-transitions",
    "typescript",
    "performance"
  ],
  "author": {
    "name": "kinetik contributors",
    "url": "https://github.com/kinetik/kinetik"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kinetik/kinetik.git"
  },
  "bugs": {
    "url": "https://github.com/kinetik/kinetik/issues"
  },
  "homepage": "https://github.com/kinetik/kinetik#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/kinetik"
  }
}
